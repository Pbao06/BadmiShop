@model Getdata1.Areas.Admin.ViewModels.CustomerIndexVM   
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Customers";
}

<main>
    @{
        // var isFilterActive = !string.IsNullOrEmpty(ViewBag.Status);
        // Kiểm tra xem người dùng có đang lọc gì không
        var isFilterActive = !string.IsNullOrEmpty(Model.SearchName)
        || !string.IsNullOrEmpty(Model.RoleSearch)
        || !string.IsNullOrEmpty(Model.StatusFilter);
        var filterClass = isFilterActive ? "filter-card show" : "filter-card";
    }
    <div class="head-title">
        <div class="left">
            <h1>Customers</h1>
            <ul class="Breakcrumb">
                <li><a href="#">Admin</a></li>
                <li><i class='bx bx-chevron-right'></i></li>
                <li><a class="active" href="#">Overview</a></li>
            </ul>
        </div>
    </div>

    <div class="table-data">
        <div class="order">
            <div class="head">
                <h3>Customer Retention</h3>
                <i class="bx @(isFilterActive ? "bx-x" : "bx-filter") filter-toggle" data-target="filterOrder" style="font-size: 20px; cursor: pointer;"></i>
            </div>

            <form method="get" asp-action="Index" asp-controller="Customer" class="@filterClass" id="filterOrder">
                <div class="filter-content">
                    <div class="filter-row">
                        <div class="filter-group search-box">
                            <i class='bx bx-search'></i>
                            <input type="text" asp-for="SearchName" placeholder="Search by name..." onchange="this.form.submit()" />
                        </div>
                        <div class="filter-group select-box">
                            <select name="RoleSearch" onchange="this.form.submit()">
                                <option value="">All Roles</option>
                                <option value="Admin" selected="@(Model.RoleSearch == "Admin")">Admin</option>
                                <option value="User" selected="@(Model.RoleSearch == "User")">User</option>
                            </select>
                        </div>
                        <div class="filter-group select-box">
                            <select name="StatusFilter" onchange="this.form.submit()">
                                <option value="">All Statuses</option>
                                <option value="VIP" selected="@(Model.StatusFilter == "VIP")">VIP</option>
                                <option value="Regular" selected="@(Model.StatusFilter == "Regular")">Regular</option>
                            </select>
                        </div>
                        <div class="filter-actions">
                            <a asp-action="Index" class="btn-reset">Reset</a>
                            <button type="submit" class="btn-primary">Filter</button>
                        </div>
                    </div>



                </div>
            </form>





            <table>
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Orders</th>
                        <th>Revenue</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cus in Model.Customers)
                    {
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center;">
                                    @* <img src="~/img/no-img.jfif" alt="@cus.Name" style="width: 32px; height: 32px; border-radius: 50%; margin-right: 12px;"> *@
                                    <p>@cus.Name</p>
                                </div>
                            </td>
                            <td>
                                <span class="status @cus.Role.ToLower()">@cus.Role</span>
                            </td>
                            <td>@cus.OrderCount</td>
                            <td>@cus.TotalSpent.ToString("#,##0") đ</td>
                            <td>
                                <span class="status @cus.Status.ToString().ToLower()">
                                    @cus.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

             @await Html.PartialAsync("pagination_table", Model)
        </div>
    </div>
</main>
